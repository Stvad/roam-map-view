{
  "name": "roam-map-view",
  "version": "0.1.0",
  "private": true,
  "description": "Roam extension: map view of recent notes using Google Timeline JSON",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "esbuild": "^0.25.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
